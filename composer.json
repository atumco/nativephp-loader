{
    "name": "atum/nativephp-loader",
    "description": "A NativePHP Mobile plugin for an animated loading screen",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Atum Ventures Ltd",
            "email": "software@atumsoft.co.uk"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Atum\\NativephpLoader\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atum\\NativephpLoader\\NativephpLoaderServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}